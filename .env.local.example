# Resend (https://resend.com) — used to send quote-request emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Email destination(s) for quote requests — comma-separated list
QUOTE_TO_EMAIL=kaylensaws@yahoo.com,sawserviceray@gmail.com

# Email "from" address (must be on a domain you've verified with Resend; for dev, use onboarding@resend.dev)
QUOTE_FROM_EMAIL=quotes@onboarding.resend.dev

# Optional: Cloudflare Turnstile (https://dash.cloudflare.com/?to=/:account/turnstile)
# Leave blank in dev to skip the verification check
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=